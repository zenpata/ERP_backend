DATABASE_URL=postgresql://user:password@localhost:5432/erp_db
JWT_SECRET=your-secret-key-min-32-chars-change-this
# Refresh token lifetime (SignJWT `exp` on refresh tokens)
JWT_EXPIRES_IN=7d
# Access token (Bearer) lifetime — keep short in production
JWT_ACCESS_EXPIRES_IN=15m
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# AP overdue background job (runs shortly after startup, then daily by default)
# AP_OVERDUE_SCHEDULER=false
# AP_OVERDUE_INTERVAL_MS=86400000

# Thai-specific
TZ=Asia/Bangkok
